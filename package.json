{
  "name": "lag-behind",
  "type": "module",
  "version": "0.0.0",
  "description": "Stay N versions behind the latest published release of your npm dependencies to avoid supply chain attacks.",
  "author": {
    "name": "Craig R Broughton",
    "email": "CRBroughton@posteo.uk",
    "url": "https://CRBroughton.me"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CRBroughton/lag-behind"
  },
  "keywords": ["npm", "security", "dependencies", "supply-chain", "audit", "version-pinning"],
  "exports": {
    ".": "./dist/src/index.js"
  },
  "bin": {
    "lag-behind": "./dist/bin/lag-behind.js"
  },
  "files": [
    "dist/bin/",
    "dist/src/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/lag-behind.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm test && pnpm build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version"
  },
  "dependencies": {
    "citty": "catalog:",
    "confbox": "catalog:",
    "defu": "catalog:",
    "destr": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:testing",
    "eslint": "catalog:",
    "jiti": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:testing"
  }
}
